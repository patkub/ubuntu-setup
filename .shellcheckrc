# Set default shell dialect to bash (overrides shebang)
shell=bash

# Enable optional checks (comma-separated)
enable=add-default-case,avoid-nullary-conditions,check-extra-masked-returns,check-set-e-suppressed,check-unassigned-uppercase,deprecate-which,quote-safe-variables,require-double-brackets,require-variable-braces

# Disable specific warnings (comma-separated)
# For more info on specific codes, see the [ShellCheck wiki](https://shellcheck.net)
# SC2250 (style): Prefer putting braces around variable references even when not strictly required.
# SC2312 (info): Consider invoking this command separately to avoid masking its return value (or use '|| true' to ignore).
disable=SC2250,SC2312
